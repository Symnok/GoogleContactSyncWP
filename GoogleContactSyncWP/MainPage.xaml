<phone:PhoneApplicationPage
    x:Class="GoogleContactSyncWP.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:phone="clr-namespace:Microsoft.Phone.Controls;assembly=Microsoft.Phone"
    xmlns:shell="clr-namespace:Microsoft.Phone.Shell;assembly=Microsoft.Phone"
    FontFamily="{StaticResource PhoneFontFamilyNormal}"
    FontSize="{StaticResource PhoneFontSizeNormal}"
    Foreground="{StaticResource PhoneForegroundBrush}"
    SupportedOrientations="Portrait" Orientation="Portrait">

    <phone:Pivot x:Name="MainPivot" Title="Google Contact Sync">

        <!-- ======== SIGN IN TAB ======== -->
        <phone:PivotItem Header="Sign in">
            <ScrollViewer>
                <StackPanel Margin="12,0,12,24">
                    <TextBlock Text="Google Account"
                               FontSize="22" FontWeight="Bold"
                               Margin="0,16,0,16"/>

                    <Border Background="#1AFFFFFF" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <Button x:Name="BtnLoadJson"
                                    Content="Load client_secret.json"
                                    HorizontalAlignment="Stretch"
                                    Height="60" FontSize="16"
                                    Click="BtnLoadJson_Click"
                                    Margin="0,0,0,16"/>

                            <TextBlock Text="Client ID" FontSize="14"
                                       Foreground="#AAAAAA" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtClientId"
                                     InputScope="Text"
                                     FontSize="16" Margin="0,0,0,12"/>

                            <TextBlock Text="Client Secret" FontSize="14"
                                       Foreground="#AAAAAA" Margin="0,0,0,4"/>
                            <PasswordBox x:Name="TxtClientSecret"
                                         FontSize="16" Margin="0,0,0,16"/>

                            <Button x:Name="BtnSignIn"
                                    Content="Sign in with Google"
                                    HorizontalAlignment="Stretch"
                                    Height="72" FontSize="18"
                                    Click="BtnSignIn_Click"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="PanelCode"
                            Background="#222222" Padding="16"
                            Visibility="Collapsed" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Open this URL in a browser:"
                                       FontSize="14" TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtVerificationUrl"
                                       FontSize="14" Foreground="#0088FF"
                                       TextWrapping="Wrap" Margin="0,0,0,16"/>
                            <TextBlock Text="Enter this code:"
                                       FontSize="14" Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtUserCode"
                                       FontSize="40" FontWeight="Bold"
                                       Foreground="Orange"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,16"/>
                            <ProgressBar IsIndeterminate="True" Height="6"/>
                            <TextBlock Text="Waiting for authorization..."
                                       FontSize="13" Foreground="#AAAAAA"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Button Content="Dump paths (diagnostic)"
                            HorizontalAlignment="Stretch"
                            Height="56" FontSize="14"
                            Click="BtnDumpPaths_Click"
                            Margin="0,8,0,0"/>

                    <TextBlock x:Name="TxtLoginStatus"
                               FontSize="14" TextWrapping="Wrap"
                               Foreground="#FF4444" Margin="0,4,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </phone:PivotItem>

        <!-- ======== SYNC TAB ======== -->
        <phone:PivotItem Header="Sync">
            <ScrollViewer>
                <StackPanel Margin="12,0,12,24">
                    <TextBlock Text="Sync Contacts"
                               FontSize="22" FontWeight="Bold"
                               Margin="0,16,0,4"/>

                    <TextBlock x:Name="TxtAccountStatus"
                               FontSize="14" Foreground="#44AA44"
                               Margin="0,0,0,12"/>

                    <Button x:Name="BtnGoogleToPhone"
                            Content="Google → Phone"
                            HorizontalAlignment="Stretch"
                            Height="72" FontSize="18"
                            IsEnabled="False"
                            Click="BtnGoogleToPhone_Click"
                            Margin="0,0,0,8"/>

                    <Button x:Name="BtnPhoneToGoogle"
                            Content="Phone → Google"
                            HorizontalAlignment="Stretch"
                            Height="72" FontSize="18"
                            IsEnabled="False"
                            Click="BtnPhoneToGoogle_Click"
                            Margin="0,0,0,8"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnSignOut"
                                Grid.Column="0"
                                Content="Sign out"
                                Height="72" FontSize="18"
                                IsEnabled="False"
                                Click="BtnSignOut_Click"
                                Margin="0,0,4,0"/>
                        <Button x:Name="BtnEmailLog"
                                Grid.Column="1"
                                Content="Email log"
                                Height="72" FontSize="18"
                                Click="BtnEmailLog_Click"
                                Margin="4,0,0,0"/>
                    </Grid>

                    <TextBlock x:Name="TxtLastSync"
                               FontSize="12" Foreground="#888888"
                               Margin="0,0,0,8"
                               Visibility="Collapsed"/>
                </StackPanel>
            </ScrollViewer>
        </phone:PivotItem>

        <!-- ======== SETTINGS TAB ======== -->
        <phone:PivotItem Header="Settings">
            <ScrollViewer>
                <StackPanel Margin="12,0,12,24">
                    <TextBlock Text="Auto Sync"
                               FontSize="22" FontWeight="Bold"
                               Margin="0,16,0,16"/>

                    <Border Background="#1AFFFFFF" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock x:Name="TxtBgStatus"
                                       FontSize="13" TextWrapping="Wrap"
                                       Foreground="#AAAAAA" Margin="0,0,0,12"/>

                            <TextBlock Text="Interval (minutes)"
                                       FontSize="14" Foreground="#AAAAAA"
                                       Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <RadioButton x:Name="Rb30"
                                             Content="30" GroupName="Interval"
                                             IsChecked="True"
                                             Checked="RbInterval_Checked"
                                             Margin="0,0,16,0"/>
                                <RadioButton x:Name="Rb60"
                                             Content="60" GroupName="Interval"
                                             Checked="RbInterval_Checked"
                                             Margin="0,0,16,0"/>
                                <RadioButton x:Name="Rb120"
                                             Content="120" GroupName="Interval"
                                             Checked="RbInterval_Checked"
                                             Margin="0,0,16,0"/>
                                <RadioButton x:Name="Rb240"
                                             Content="240" GroupName="Interval"
                                             Checked="RbInterval_Checked"/>
                            </StackPanel>

                            <Button x:Name="BtnToggleBgSync"
                                    Content="Enable auto sync"
                                    HorizontalAlignment="Stretch"
                                    Height="72" FontSize="18"
                                    IsEnabled="False"
                                    Click="BtnToggleBgSync_Click"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </phone:PivotItem>

        <!-- ======== LOG TAB ======== -->
        <phone:PivotItem Header="Log">
            <Grid Margin="12,8,12,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Button x:Name="BtnClearLog"
                        Grid.Row="0"
                        Content="Clear log"
                        HorizontalAlignment="Right"
                        Height="56" FontSize="14"
                        Click="BtnClearLog_Click"
                        Margin="0,0,0,4"/>

                <Border Grid.Row="1" Background="#111111" Padding="8">
                    <ScrollViewer x:Name="LogScroller">
                        <TextBlock x:Name="TxtLog"
                                   FontSize="13"
                                   FontFamily="Courier New"
                                   TextWrapping="Wrap"
                                   Foreground="#CCCCCC"/>
                    </ScrollViewer>
                </Border>
            </Grid>
        </phone:PivotItem>

    </phone:Pivot>
</phone:PhoneApplicationPage>
